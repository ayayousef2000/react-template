echo "🔍 Running pre-commit checks..."

# ── Guard: skip all checks if the project hasn't been scaffolded yet ──────────
# Husky + commitlint are installed on the template before any framework exists.
# Once the developer scaffolds their project (pnpm install), node_modules will
# be present and all checks below will activate automatically.
if [ ! -d "node_modules" ]; then
  echo "⏭  node_modules not found — project not yet scaffolded, skipping checks"
  exit 0
fi

STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_TS" ]; then
  echo "  → Biome lint + format check..."
  echo "$STAGED_TS" | xargs pnpm exec biome check --no-errors-on-unmatched || {
    echo "❌ Biome check failed. Run: pnpm exec biome check --write <file>"
    exit 1
  }

  if [ -f "tsconfig.json" ]; then
    echo "  → TypeScript check..."
    pnpm exec tsc --noEmit --skipLibCheck 2>/dev/null || {
      echo "❌ TypeScript errors found. Run: pnpm typecheck"
      exit 1
    }
  fi

  echo "  → Checking for console.log / debugger..."
  if echo "$STAGED_TS" | xargs grep -En 'debugger|console\.log\(' 2>/dev/null; then
    echo "⚠️  console.log or debugger found — remove before committing."
    exit 1
  fi
fi

echo "  → Checking for .env files..."
STAGED_ENV=$(git diff --cached --name-only | grep -E '^\.env' | grep -v '\.example$' || true)
if [ -n "$STAGED_ENV" ]; then
  echo "❌ Attempting to commit secret file: $STAGED_ENV"
  exit 1
fi

echo "✅ Pre-commit checks passed"
